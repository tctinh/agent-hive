{
  "name": "vscode-hive",
  "displayName": "Agent Hive",
  "description": "From Vibe Coding to Hive Coding - Review and approve AI-generated plans",
  "version": "1.3.6",
  "publisher": "tctinh",
  "license": "MIT WITH Commons-Clause",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tctinh/agent-hive.git",
    "directory": "packages/vscode-hive"
  },
  "homepage": "https://github.com/tctinh/agent-hive#readme",
  "bugs": {
    "url": "https://github.com/tctinh/agent-hive/issues"
  },
  "keywords": [
    "ai",
    "hive",
    "vibe-coding",
    "opencode",
    "planning",
    "workflow",
    "copilot",
    "agents",
    "subagent",
    "multi-agent"
  ],
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelTools": [
      {
        "name": "hive_feature_create",
        "displayName": "Create Hive Feature",
        "modelDescription": "Create a new Hive feature for plan-first development. Use at the start of any new work to establish a planning workspace with context, plan, and task tracking.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveFeatureCreate",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Feature name (kebab-case recommended)"
            },
            "ticket": {
              "type": "string",
              "description": "Optional ticket/issue reference"
            }
          },
          "required": [
            "name"
          ]
        }
      },
      {
        "name": "hive_feature_complete",
        "displayName": "Complete Hive Feature",
        "modelDescription": "Mark a feature as completed. Use when all tasks are done and the feature is ready for final integration. This is irreversible.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveFeatureComplete",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Feature name to mark as completed"
            }
          },
          "required": [
            "name"
          ]
        }
      },
      {
        "name": "hive_plan_write",
        "displayName": "Write Hive Plan",
        "modelDescription": "Write or update the plan.md for a feature. plan.md is the human-facing review surface and execution truth. Include a concise summary before ## Tasks, and optionally include a Mermaid dependency or sequence overview in that pre-task summary only. Use markdown with ### numbered headers for tasks. Clears existing plan review comments when plan is rewritten.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hivePlanWrite",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "content": {
              "type": "string",
              "description": "Plan content in markdown. Use ### 1. Task Name format for tasks."
            }
          },
          "required": [
            "feature",
            "content"
          ]
        }
      },
      {
        "name": "hive_plan_read",
        "displayName": "Read Hive Plan",
        "modelDescription": "Read the plan.md and related review comments for a feature. Use to check the in-plan human-facing summary, task structure, status, and user feedback before making changes.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hivePlanRead",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            }
          },
          "required": [
            "feature"
          ]
        }
      },
      {
        "name": "hive_plan_approve",
        "displayName": "Approve Hive Plan",
        "modelDescription": "Approve a plan for execution. Use after the user has reviewed plan.md, including the human-facing summary before ## Tasks, and resolved any comments. Changes feature status to approved.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hivePlanApprove",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            }
          },
          "required": [
            "feature"
          ]
        }
      },
      {
        "name": "hive_tasks_sync",
        "displayName": "Sync Hive Tasks",
        "modelDescription": "Generate tasks from an approved plan. Parses ### numbered headers and creates task folders. Use after hive_plan_approve to create executable tasks.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveTasksSync",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            }
          },
          "required": [
            "feature"
          ]
        }
      },
      {
        "name": "hive_task_create",
        "displayName": "Create Manual Task",
        "modelDescription": "Create a task manually, not from the plan. Use for ad-hoc work or tasks discovered during execution.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveTaskCreate",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "name": {
              "type": "string",
              "description": "Task name"
            },
            "order": {
              "type": "number",
              "description": "Optional order number for the task"
            }
          },
          "required": [
            "feature",
            "name"
          ]
        }
      },
      {
        "name": "hive_task_update",
        "displayName": "Update Hive Task",
        "modelDescription": "Update a task status or summary. Use to track progress or add notes about completed work.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveTaskUpdate",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "task": {
              "type": "string",
              "description": "Task folder name"
            },
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "in_progress",
                "done",
                "cancelled"
              ],
              "description": "New status"
            },
            "summary": {
              "type": "string",
              "description": "Summary of what was done"
            }
          },
          "required": [
            "feature",
            "task"
          ]
        }
      },
      {
        "name": "hive_worktree_start",
        "displayName": "Start Task Worktree",
        "modelDescription": "Create a git worktree for a pending/in-progress task. Use for normal task starts.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveWorktreeStart",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "task": {
              "type": "string",
              "description": "Task folder name"
            }
          },
          "required": [
            "feature",
            "task"
          ]
        }
      },
      {
        "name": "hive_worktree_create",
        "displayName": "Resume Blocked Task Worktree",
        "modelDescription": "Resume a blocked task in its existing worktree. Requires continueFrom: \"blocked\" and a decision.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveWorktreeCreate",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "task": {
              "type": "string",
              "description": "Task folder name"
            },
            "continueFrom": {
              "type": "string",
              "enum": [
                "blocked"
              ],
              "description": "Resume a blocked task"
            },
            "decision": {
              "type": "string",
              "description": "Answer to blocker question when continuing"
            }
          },
          "required": [
            "feature",
            "task",
            "continueFrom"
          ]
        }
      },
      {
        "name": "hive_worktree_commit",
        "displayName": "Commit Task Worktree",
        "modelDescription": "Commit changes in worktree and mark task done. Does NOT merge - use hive_merge for that. Use when task implementation is finished.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveWorktreeCommit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "task": {
              "type": "string",
              "description": "Task folder name"
            },
            "summary": {
              "type": "string",
              "description": "Summary of what was done"
            },
            "message": {
              "type": "string",
              "description": "Optional git commit message; subject/body allowed. Empty uses default."
            }
          },
          "required": [
            "feature",
            "task",
            "summary"
          ]
        }
      },
      {
        "name": "hive_worktree_discard",
        "displayName": "Discard Task Worktree",
        "modelDescription": "Discard all changes and remove worktree. Use when task approach is wrong and needs restart. This is destructive and irreversible.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveWorktreeDiscard",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "task": {
              "type": "string",
              "description": "Task folder name"
            }
          },
          "required": [
            "feature",
            "task"
          ]
        }
      },
      {
        "name": "hive_status",
        "displayName": "Get Hive Status",
        "modelDescription": "Get comprehensive status of a feature including plan, tasks, and context. Returns JSON with all relevant state for resuming work.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveStatus",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name (optional, uses active feature if omitted)"
            }
          }
        }
      },
      {
        "name": "hive_merge",
        "displayName": "Merge Task Branch",
        "modelDescription": "Merge a completed task branch into current branch. Supports merge, squash, or rebase strategies. Use after hive_exec_complete to integrate changes.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveMerge",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "task": {
              "type": "string",
              "description": "Task folder name"
            },
            "strategy": {
              "type": "string",
              "enum": [
                "merge",
                "squash",
                "rebase"
              ],
              "description": "Merge strategy (default: merge)"
            },
            "message": {
              "type": "string",
              "description": "Optional merge commit message for merge/squash only. Empty uses default."
            },
            "preserveConflicts": {
              "type": "boolean",
              "description": "Keep merge conflict state intact instead of auto-aborting (default: false)."
            },
            "cleanup": {
              "type": "string",
              "enum": [
                "none",
                "worktree",
                "worktree+branch"
              ],
              "description": "Cleanup mode after a successful merge (default: none)."
            }
          },
          "required": [
            "feature",
            "task"
          ]
        }
      },
      {
        "name": "hive_context_write",
        "displayName": "Write Context File",
        "modelDescription": "Write a context file to store research findings, decisions, or reference material. Context persists across sessions.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveContextWrite",
        "inputSchema": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "description": "Feature name"
            },
            "name": {
              "type": "string",
              "description": "Context file name (without .md)"
            },
            "content": {
              "type": "string",
              "description": "Context content in markdown"
            }
          },
          "required": [
            "feature",
            "name",
            "content"
          ]
        }
      },
      {
        "name": "hive_agents_md",
        "displayName": "Manage AGENTS.md",
        "modelDescription": "Initialize, sync, or apply changes to AGENTS.md. Actions: init (scan and generate), sync (update from context), apply (write to disk).",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveAgentsMd",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "init",
                "sync",
                "apply"
              ],
              "description": "Action to perform"
            },
            "feature": {
              "type": "string",
              "description": "Feature name (required for sync)"
            },
            "content": {
              "type": "string",
              "description": "Content to apply (required for apply)"
            }
          },
          "required": [
            "action"
          ]
        }
      },
      {
        "name": "hive_skill",
        "displayName": "Load Hive Skill",
        "modelDescription": "Load a skill by name from .github/skills/, .claude/skills/, or .opencode/skill/. Returns the SKILL.md content with workflow instructions.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "hiveSkill",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Skill name (e.g. writing-plans, brainstorming, test-driven-development)"
            }
          },
          "required": [
            "name"
          ]
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hive",
          "title": "Hive",
          "icon": "resources/icons/hive.svg"
        }
      ]
    },
    "views": {
      "hive": [
        {
          "id": "hive.features",
          "name": "Features"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "hive.features",
        "contents": "No Hive nest found in this workspace.\n\n[Init Hive Nest](command:hive.initNest)\n\nThis will create:\n- Copilot agents (.github/agents/)\n- Agent skills (.github/skills/)\n- Workflow hooks (.github/hooks/)\n- Instructions (.github/instructions/)\n- Plugin manifest (plugin.json)\n- Claude skills (.claude/skills/)\n- OpenCode skills (.opencode/skill/)",
        "when": "!hive.hasHiveRoot"
      }
    ],
    "commands": [
      {
        "command": "hive.initNest",
        "title": "Hive: Init Nest",
        "icon": "$(home)"
      },
      {
        "command": "hive.newFeature",
        "title": "Hive: New Feature",
        "icon": "$(add)"
      },
      {
        "command": "hive.refresh",
        "title": "Hive: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "hive.regenerateAgents",
        "title": "Hive: Regenerate Agents",
        "icon": "$(sync)"
      },
      {
        "command": "hive.openFile",
        "title": "Open File"
      },
      {
        "command": "hive.plan.doneReview",
        "title": "Done Review",
        "icon": "$(check)"
      },
      {
        "command": "hive.comment.create",
        "title": "Add Comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "hive.comment.reply",
        "title": "Reply",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "hive.comment.resolve",
        "title": "Resolve Thread"
      },
      {
        "command": "hive.comment.delete",
        "title": "Delete Comment"
      },
      {
        "command": "hive.approvePlan",
        "title": "Approve Plan",
        "icon": "$(check)"
      },
      {
        "command": "hive.syncTasks",
        "title": "Generate Tasks",
        "icon": "$(list-tree)"
      },
      {
        "command": "hive.startTask",
        "title": "Start Task",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hive.newFeature",
          "when": "view == hive.features",
          "group": "navigation"
        },
        {
          "command": "hive.refresh",
          "when": "view == hive.features",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "hive.openFile",
          "when": "viewItem == file"
        },
        {
          "command": "hive.approvePlan",
          "when": "viewItem == plan-draft",
          "group": "inline"
        },
        {
          "command": "hive.syncTasks",
          "when": "viewItem =~ /^feature-(approved|executing)$/",
          "group": "inline"
        },
        {
          "command": "hive.startTask",
          "when": "viewItem == task-pending",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "hive.plan.doneReview",
          "when": "resourceFilename =~ /^(plan|overview)\\.md$/",
          "group": "navigation"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "hive.comment.create",
          "group": "inline",
          "when": "commentController == hive-plan-review && commentThreadIsEmpty"
        },
        {
          "command": "hive.comment.reply",
          "group": "inline",
          "when": "commentController == hive-plan-review && !commentThreadIsEmpty"
        },
        {
          "command": "hive.comment.resolve",
          "group": "inline",
          "when": "commentController == hive-plan-review && !commentThreadIsEmpty"
        }
      ],
      "comments/comment/title": [
        {
          "command": "hive.comment.delete",
          "group": "inline",
          "when": "commentController == hive-plan-review"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --define:import.meta.url=__importMetaUrl --banner:js=\"const __importMetaUrl = require('url').pathToFileURL(__filename).href;\" && vsce package --no-dependencies -o vscode-hive.vsix",
    "watch": "npm run build -- --watch",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "hive-core": "workspace:*"
  }
}
